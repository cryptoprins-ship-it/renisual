# Copy this file to .env.local (gitignored) and fill in the real values.
# Production env vars live in the Vercel/Hostinger dashboard, not here.

# Public site URL — used in metadata, sitemap, hreflang alternates.
NEXT_PUBLIC_APP_URL=https://renisual.com

# Gemini for /api/render. Mixed-case names are also accepted by the
# resolver (see resolveGeminiKey in app/api/render/route.ts) but the
# canonical name is GEMINI_API_KEY.
GEMINI_API_KEY=your-gemini-key-here

# OpenAI fallback for /api/render-openai (pro tier, deferred).
OPENAI_API_KEY=sk-your-openai-key-here

# SMTP for offerte + waitlist confirmation mails. Hostinger or Mailgun
# both work — set secure: true on port 465 in nodemailer.
SMTP_HOST=smtp.example.com
SMTP_PORT=465
SMTP_USER=info@renisual.com
SMTP_PASS=your-smtp-password

# Supabase. Backs /offerte/[ref] pages, /api/offertes, /api/credits,
# and signed-URL access to private storage buckets. Secret key MUST
# stay server-side; only NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY ships
# to the browser, and only if Row Level Security is on for every
# exposed table.
#
# Naming note: Supabase renamed "anon key" → "publishable key" and
# "service_role" → "secret key" in 2026. New projects only show the
# new names in the dashboard; legacy projects show the old ones.
# utils/supabase/admin.ts already reads either SUPABASE_SECRET_KEY
# or SUPABASE_SERVICE_ROLE_KEY, but the public-side files (proxy,
# server, client) require the new PUBLISHABLE name — copy the value
# of your anon key into that var if your dashboard still labels it
# as "anon".
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SECRET_KEY=your-secret-key

# Upstash Redis for rate limiting. Critical here — /api/render burns
# Gemini quota, and a missing limiter means an attacker could empty
# your monthly quota in minutes. Without these the lib falls back to
# an in-process limiter that does NOT survive across serverless invocations.
# Get them at: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://your-instance.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# Logger verbosity: trace | debug | info | warn | error
LOG_LEVEL=info
